---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Case Studies - My Design Portfolio',
};

// Case study data - you can move this to a separate constants file
const csChipData = [
  { label: 'Web App', number: 3 },
  { label: 'Mobile App', number: 2 },
  { label: 'UI/UX Design', number: 4 },
  { label: 'Product Design', number: 2 }
];

// Sample case study data - replace with your actual data
const caseStudyData = [
  {
    id: 1,
    title: 'Mercedes-Benz Digital Experience',
    description: 'Redesigning the luxury car buying experience through digital innovation',
    category: 'Web App',
    imgSrc: '/assets/dataimages/benz.png',
    pathName: '/case-study/mercedes-benz',
    tags: ['UX Research', 'Interface Design', 'Prototyping']
  },
  {
    id: 2,
    title: 'Paysafe Payment Platform',
    description: 'Streamlining digital payments with intuitive design',
    category: 'Web App',
    imgSrc: '/assets/dataimages/Paysafe.png',
    pathName: '/case-study/paysafe',
    tags: ['Fintech', 'Mobile Design', 'User Journey']
  },
  {
    id: 3,
    title: 'NoBroker Property Platform',
    description: 'Revolutionizing real estate discovery and transactions',
    category: 'Mobile App',
    imgSrc: '/assets/dataimages/NoBroker.png',
    pathName: '/case-study/nobroker',
    tags: ['Mobile App', 'Property Tech', 'User Research']
  },
  {
    id: 4,
    title: 'Cisco Enterprise Solutions',
    description: 'Enterprise networking solutions with enhanced usability',
    category: 'Web App',
    imgSrc: '/assets/dataimages/Cisco.png',
    pathName: '/case-study/cisco',
    tags: ['Enterprise UX', 'Dashboard Design', 'B2B']
  }
];
---

<Layout metadata={metadata}>
  <div class='case-studies-container'>
    <div class='case-studies-header'>
      <span class='case-studies-header-creativity'>creativity</span>
      <div class='case-studies-header-divider'>
        <span class='with'>WITH</span>
        <img
          src="/assets/circle.svg"
          alt='circle'
          style="margin-top: -75px; margin-left: -18px; margin-right: -135px; width: 454px;"
        />
      </div>
      <div class='case-studies-header-purpose'>
        <span>purpose</span>
      </div>
    </div>

    <div class='case-studies-intro'>
      <span class='case-studies-intro-text'>
        Looking for my portfolio? You'll find here some shots of my most
        recent projects, an exhaustive list of all the projects I contributed
        to, as well as a few words about my role and my inspirations.
      </span>
    </div>

    <div class='case-studies-design-process'>
      <div class='case-studies-process-details'>
        <span class='case-studies-process-title'>My Design Process</span>
        <span class='case-studies-process-description'>
          My design process varies slightly depending on the nature of the
          project at hand. Am I redesigning an existing product, creating a
          new product from scratch, adding new features to an already existing
          product.
        </span>
      </div>
      <a href='/designprocess' style="text-decoration: none;">
        <button class='case-studies-open-document-button'>
          Open Document
          <img src="/assets/caseStudiesModal/white-arrow.svg" alt='arrow' />
        </button>
      </a>
    </div>

    <div class='case-studies-footer'>
      <span class='case-studies-footer-text'>// Casestudies</span>
      <div class='cs-chip-container-holder' id="chip-container">
        {csChipData.map((eachChip, idx) => (
          <button 
            class="cs-chip"
            data-filter={eachChip.label}
            data-count={eachChip.number}
            key={idx}
          >
            <span class="chip-label">{eachChip.label}</span>
            <span class="chip-count">({eachChip.number})</span>
          </button>
        ))}
      </div>
    </div>

    <div class='cs-card-container' id="case-studies-container">
      {caseStudyData.map((caseStudy) => (
        <article class="case-study-card" data-category={caseStudy.category}>
          <a href={caseStudy.pathName} class="card-link">
            <div class="card-image-container">
              <img 
                src={caseStudy.imgSrc} 
                alt={caseStudy.title}
                class="card-image"
                loading="lazy"
              />
              <div class="card-overlay">
                <Icon name="tabler:external-link" class="external-link-icon" />
              </div>
            </div>
            <div class="card-content">
              <h3 class="card-title">{caseStudy.title}</h3>
              <p class="card-description">{caseStudy.description}</p>
              <div class="card-tags">
                {caseStudy.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- Horizontal containers for smaller cards (if needed) -->
    <!-- <div class='cs-horz-container'>
      Additional small cards can go here
    </div> -->
  </div>

  <!-- Call to Action -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'View All Projects',
        href: '/projects',
      },
      {
        variant: 'secondary',
        text: 'Contact Me',
        href: '/contact',
      },
    ]}
    title="Interested in working together?"
    subtitle="Let's create something amazing together. I'm always open to discussing new projects and opportunities."
  />
</Layout>

<script>
  function initializeCaseStudiesFilter() {
    const chips = document.querySelectorAll('.cs-chip');
    const caseStudyCards = document.querySelectorAll('.case-study-card');
    
    if (!chips.length || !caseStudyCards.length) return;

    function filterCaseStudies(filter: string) {
      caseStudyCards.forEach((card) => {
        const cardElement = card as HTMLElement;
        const category = cardElement.dataset.category;
        
        if (filter === 'all' || category === filter || filter === '') {
          cardElement.style.display = 'block';
        } else {
          cardElement.style.display = 'none';
        }
      });
    }

    function setActiveChip(activeChip: Element) {
      chips.forEach(chip => chip.classList.remove('active'));
      activeChip.classList.add('active');
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const filter = target.dataset.filter;
        
        if (filter) {
          setActiveChip(target);
          filterCaseStudies(filter);
        }
      });
    });

    // Initialize - show all cards
    filterCaseStudies('all');
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initializeCaseStudiesFilter);
  
  // Handle Astro page navigation
  document.addEventListener('astro:page-load', initializeCaseStudiesFilter);
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Abhaya+Libre:wght@500&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Akshar:wght@500&display=swap');

  .case-studies-container {
    padding: 42px 31px 214px 30px;
  }

  .case-studies-intro {
    display: flex;
    flex-direction: column;
    gap: 38px;
    padding-bottom: 20px;
  }

  .case-studies-intro-text {
    color: #b8c1cc;
    font-family: Inter;
    font-size: 19.375px;
    font-style: normal;
    font-weight: 300;
    line-height: 36px; /* 185.806% */
  }

  .case-studies-design-process {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #14181f;
    border-bottom: 1px solid #14181f;
    margin-bottom: 22px;
  }

  .case-studies-process-details {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px 0px 20px 0px;
  }

  .case-studies-process-title {
    color: #f8fafc;
    font-family: Inter;
    font-size: 30.5px;
    font-style: normal;
    font-weight: 900;
    line-height: 40px; /* 131.148% */
    letter-spacing: -0.44px;
  }

  .case-studies-process-description {
    color: #b8c1cc;
    font-family: Inter;
    font-size: 15.375px;
    font-style: normal;
    font-weight: 300;
    line-height: 24px; /* 156.098% */
  }

  .case-studies-open-document-button {
    width: 178.84px;
    height: 48px;
    flex-shrink: 0;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: #14191f;
    color: #f8fafc;
    font-family: Inter;
    font-size: 17.438px;
    font-style: normal;
    font-weight: 500;
    line-height: 24px; /* 137.634% */
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }

  .case-studies-footer {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .cs-chip-container-holder {
    display: flex;
    gap: 10px;
  }

  .cs-card-container {
    margin-top: 50px;
  }

  .cs-horz-container {
    display: flex;
    gap: 16px;
  }

  .case-studies-header {
    display: flex;
    flex-direction: column;
    max-width: 678px;
  }

  .case-studies-header-creativity {
    color: #fff;
    font-family: 'Akshar', sans-serif;
    font-size: 78.291px;
    font-style: normal;
    font-weight: 500;
    line-height: 100%; /* 78.291px */
    letter-spacing: -0.899px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .case-studies-header-divider {
    display: flex;
    justify-content: end;
  }

  .case-studies-header-purpose {
    color: #fff;
    font-family: 'Akshar', sans-serif;
    font-size: 78.291px;
    font-style: normal;
    font-weight: 500;
    line-height: 100%; /* 78.291px */
    letter-spacing: -0.899px;
    text-transform: uppercase;
    display: flex;
    flex-direction: row;
    justify-content: end;
    margin-top: -150px;
    margin-right: -80px;
    margin-bottom: 58px;
  }

  .with {
    color: var(--neon, #b2ff50);
    font-family: 'Abhaya Libre', serif;
    font-size: 17.985px;
    font-style: normal;
    font-weight: 500;
    line-height: 100%; /* 17.985px */
    letter-spacing: 0.18px;
    text-transform: uppercase;
  }

  .case-studies-footer-text {
    color: #b8c1cc;
    font-family: 'Fira Code', monospace;
    font-size: 16px;
    font-weight: 400;
  }

  /* CS Chip Styles */
  .cs-chip {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 16px;
    background: transparent;
    border: 1px solid #b8c1cc;
    border-radius: 20px;
    color: #b8c1cc;
    font-family: Inter;
    font-size: 14px;
    font-weight: 400;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cs-chip:hover {
    border-color: #b2ff50;
    color: #b2ff50;
  }

  .cs-chip.active {
    background: #b2ff50;
    border-color: #b2ff50;
    color: #000;
  }

  .chip-label {
    color: inherit;
  }

  .chip-count {
    color: inherit;
    opacity: 0.8;
  }

  /* Case Study Card Styles */
  .case-study-card {
    margin-bottom: 24px;
    transition: all 0.3s ease;
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-image-container {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
  }

  .card-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }

  .case-study-card:hover .card-image {
    transform: scale(1.05);
  }

  .card-overlay {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 40px;
    height: 40px;
    background: rgba(0, 0, 0, 0.7);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .case-study-card:hover .card-overlay {
    opacity: 1;
  }

  .external-link-icon {
    width: 20px;
    height: 20px;
    color: #fff;
  }

  .card-content {
    padding: 16px 0;
  }

  .card-title {
    color: #f8fafc;
    font-family: Inter;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 8px;
  }

  .card-description {
    color: #b8c1cc;
    font-family: Inter;
    font-size: 16px;
    font-weight: 300;
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    padding: 4px 12px;
    background: rgba(178, 255, 80, 0.1);
    border: 1px solid #b2ff50;
    color: #b2ff50;
    font-family: Inter;
    font-size: 12px;
    font-weight: 400;
    border-radius: 16px;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .case-studies-container {
      padding: 24px 16px 120px 16px;
    }

    .case-studies-header-creativity,
    .case-studies-header-purpose {
      font-size: 48px;
    }

    .case-studies-header-purpose {
      margin-top: -100px;
      margin-right: -40px;
    }

    .case-studies-design-process {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }

    .case-studies-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .cs-chip-container-holder {
      flex-wrap: wrap;
    }
  }
</style>
