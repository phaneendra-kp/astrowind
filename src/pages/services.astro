---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Case Studies - My Design Portfolio',
};

// Case study data - you can move this to a separate constants file
const csChipData = [
  { label: 'Web App', number: 3 },
  { label: 'Mobile App', number: 2 },
  { label: 'UI/UX Design', number: 4 },
  { label: 'Product Design', number: 2 }
];

// Sample case study data - replace with your actual data
const caseStudyData = [
  {
    id: 1,
    title: 'Mercedes-Benz Digital Experience',
    description: 'Redesigning the luxury car buying experience through digital innovation',
    category: 'Web App',
    imgSrc: '/assets/dataimages/benz.png',
    pathName: '/case-study/mercedes-benz',
    tags: ['UX Research', 'Interface Design', 'Prototyping']
  },
  {
    id: 2,
    title: 'Paysafe Payment Platform',
    description: 'Streamlining digital payments with intuitive design',
    category: 'Web App',
    imgSrc: '/assets/dataimages/Paysafe.png',
    pathName: '/case-study/paysafe',
    tags: ['Fintech', 'Mobile Design', 'User Journey']
  },
  {
    id: 3,
    title: 'NoBroker Property Platform',
    description: 'Revolutionizing real estate discovery and transactions',
    category: 'Mobile App',
    imgSrc: '/assets/dataimages/NoBroker.png',
    pathName: '/case-study/nobroker',
    tags: ['Mobile App', 'Property Tech', 'User Research']
  },
  {
    id: 4,
    title: 'Cisco Enterprise Solutions',
    description: 'Enterprise networking solutions with enhanced usability',
    category: 'Web App',
    imgSrc: '/assets/dataimages/Cisco.png',
    pathName: '/case-study/cisco',
    tags: ['Enterprise UX', 'Dashboard Design', 'B2B']
  }
];
---

<Layout metadata={metadata}>
  <!-- Case Studies Hero Section -->
  <section class="case-studies-hero px-4 py-16 sm:px-6 lg:px-8 lg:py-20 mx-auto max-w-7xl">
    <div class='case-studies-header'>
      <div class="header-content">
        <span class='case-studies-header-creativity'>creativity</span>
        <div class='case-studies-header-divider'>
          <span class='with'>WITH</span>
          <div class="circle-decoration"></div>
        </div>
        <div class='case-studies-header-purpose'>
          <span>purpose</span>
        </div>
      </div>
    </div>
    
    <div class='case-studies-intro'>
      <span class='case-studies-intro-text'>
        Looking for my portfolio? You'll find here some shots of my most
        recent projects, an exhaustive list of all the projects I contributed
        to, as well as a few words about my role and my inspirations.
      </span>
    </div>
    
    <div class='case-studies-design-process'>
      <div class='case-studies-process-details'>
        <span class='case-studies-process-title'>My Design Process</span>
        <span class='case-studies-process-description'>
          My design process varies slightly depending on the nature of the
          project at hand. Am I redesigning an existing product, creating a
          new product from scratch, adding new features to an already existing
          product.
        </span>
      </div>
      <a href='/design-process' class="design-process-link">
        <button class='case-studies-open-document-button'>
          <span>Open Document</span>
          <Icon name="tabler:arrow-right" class="arrow-icon" />
        </button>
      </a>
    </div>
  </section>

  <!-- Filter Section -->
  <section class="filter-section px-4 sm:px-6 lg:px-8 mx-auto max-w-7xl">
    <div class='case-studies-footer'>
      <span class='case-studies-footer-text'>// Case Studies</span>
      <div class='cs-chip-container-holder' id="chip-container">
        {csChipData.map((eachChip, idx) => (
          <button 
            class="cs-chip"
            data-filter={eachChip.label}
            data-count={eachChip.number}
            key={idx}
          >
            <span class="chip-label">{eachChip.label}</span>
            <span class="chip-count">({eachChip.number})</span>
          </button>
        ))}
        <button class="cs-chip active" data-filter="all">
          <span class="chip-label">All Projects</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Case Studies Grid -->
  <section class="case-studies-grid px-4 pb-16 sm:px-6 lg:px-8 lg:pb-20 mx-auto max-w-7xl">
    <div class='cs-card-container' id="case-studies-container">
      {caseStudyData.map((caseStudy) => (
        <article class="case-study-card" data-category={caseStudy.category}>
          <a href={caseStudy.pathName} class="card-link">
            <div class="card-image-container">
              <img 
                src={caseStudy.imgSrc} 
                alt={caseStudy.title}
                class="card-image"
                loading="lazy"
              />
              <div class="card-overlay">
                <Icon name="tabler:external-link" class="external-link-icon" />
              </div>
            </div>
            <div class="card-content">
              <h3 class="card-title">{caseStudy.title}</h3>
              <p class="card-description">{caseStudy.description}</p>
              <div class="card-tags">
                {caseStudy.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
    
    <!-- Empty State -->
    <div id="empty-state" class="empty-state hidden">
      <Icon name="tabler:folder-open" class="empty-icon" />
      <h3>No projects found</h3>
      <p>Try selecting a different filter or view all projects.</p>
    </div>
  </section>

  <!-- Call to Action -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'View All Projects',
        href: '/projects',
      },
      {
        variant: 'secondary',
        text: 'Contact Me',
        href: '/contact',
      },
    ]}
    title="Interested in working together?"
    subtitle="Let's create something amazing together. I'm always open to discussing new projects and opportunities."
  />
</Layout>

<script>
  function initializeCaseStudiesFilter() {
    const chips = document.querySelectorAll('.cs-chip');
    const caseStudyCards = document.querySelectorAll('.case-study-card');
    const container = document.getElementById('case-studies-container');
    const emptyState = document.getElementById('empty-state');
    
    if (!chips.length || !caseStudyCards.length) return;

    function filterCaseStudies(filter: string) {
      let visibleCount = 0;
      
      caseStudyCards.forEach((card) => {
        const cardElement = card as HTMLElement;
        const category = cardElement.dataset.category;
        
        if (filter === 'all' || category === filter) {
          cardElement.style.display = 'block';
          cardElement.style.animation = 'fadeInUp 0.6s ease forwards';
          visibleCount++;
        } else {
          cardElement.style.display = 'none';
        }
      });
      
      // Show/hide empty state
      if (emptyState && container) {
        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
          container.classList.add('hidden');
        } else {
          emptyState.classList.add('hidden');
          container.classList.remove('hidden');
        }
      }
    }

    function setActiveChip(activeChip: Element) {
      chips.forEach(chip => chip.classList.remove('active'));
      activeChip.classList.add('active');
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const filter = target.dataset.filter;
        
        if (filter) {
          setActiveChip(target);
          filterCaseStudies(filter);
        }
      });
    });

    // Set initial state - show all
    const allChip = document.querySelector('[data-filter="all"]');
    if (allChip) {
      setActiveChip(allChip);
      filterCaseStudies('all');
    }
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initializeCaseStudiesFilter);
  
  // Handle Astro page navigation
  document.addEventListener('astro:page-load', initializeCaseStudiesFilter);
</script>

<style>
  /* Hero Section Styles */
  .case-studies-hero {
    text-align: center;
    position: relative;
  }

  .case-studies-header {
    margin-bottom: 3rem;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .case-studies-header-creativity {
    font-size: clamp(2.5rem, 8vw, 6rem);
    font-weight: 300;
    color: var(--aw-color-text-default);
    letter-spacing: -0.02em;
  }

  .case-studies-header-divider {
    position: relative;
    display: flex;
    align-items: center;
  }

  .with {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--aw-color-text-muted);
    margin: 0 1rem;
  }

  .circle-decoration {
    width: 120px;
    height: 120px;
    border: 2px solid var(--aw-color-primary);
    border-radius: 50%;
    opacity: 0.3;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .case-studies-header-purpose span {
    font-size: clamp(2.5rem, 8vw, 6rem);
    font-weight: 700;
    background: linear-gradient(135deg, var(--aw-color-primary) 0%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .case-studies-intro {
    max-width: 800px;
    margin: 0 auto 4rem;
  }

  .case-studies-intro-text {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--aw-color-text-muted);
  }

  .case-studies-design-process {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    border-radius: 16px;
    gap: 2rem;
  }

  .case-studies-process-details {
    flex: 1;
    text-align: left;
  }

  .case-studies-process-title {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    margin-bottom: 0.5rem;
  }

  .case-studies-process-description {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
  }

  .design-process-link {
    text-decoration: none;
  }

  .case-studies-open-document-button {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.5rem;
    background: linear-gradient(135deg, var(--aw-color-primary) 0%, #8b5cf6 100%);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.3);
  }

  .case-studies-open-document-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(59, 130, 246, 0.4);
  }

  .arrow-icon {
    width: 20px;
    height: 20px;
  }

  /* Filter Section */
  .filter-section {
    border-bottom: 1px solid var(--aw-color-border);
    padding-bottom: 2rem;
  }

  .case-studies-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .case-studies-footer-text {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--aw-color-text-muted);
    font-family: 'Fira Code', monospace;
  }

  .cs-chip-container-holder {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cs-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--aw-color-bg-page);
    border: 2px solid var(--aw-color-border);
    border-radius: 25px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .cs-chip:hover {
    border-color: var(--aw-color-primary);
    transform: translateY(-1px);
  }

  .cs-chip.active {
    background: var(--aw-color-primary);
    border-color: var(--aw-color-primary);
    color: white;
  }

  .chip-label {
    color: inherit;
  }

  .chip-count {
    font-size: 0.75rem;
    opacity: 0.7;
  }

  /* Case Studies Grid */
  .case-studies-grid {
    padding-top: 3rem;
  }

  .cs-card-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .case-study-card {
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s ease;
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }

  .case-study-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    border-color: var(--aw-color-primary);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-image-container {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .case-study-card:hover .card-image {
    transform: scale(1.05);
  }

  .card-overlay {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .case-study-card:hover .card-overlay {
    opacity: 1;
  }

  .external-link-icon {
    width: 20px;
    height: 20px;
    color: var(--aw-color-text-default);
  }

  .card-content {
    padding: 1.5rem;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .card-description {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
    margin-bottom: 1rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: var(--aw-color-primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: 15px;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--aw-color-text-muted);
  }

  .empty-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 1rem;
    opacity: 0.5;
  }

  .empty-state h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--aw-color-text-default);
  }

  .hidden {
    display: none;
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .case-studies-design-process {
      flex-direction: column;
      text-align: center;
    }
    
    .case-studies-process-details {
      text-align: center;
    }
  }

  @media (max-width: 768px) {
    .case-studies-footer {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .cs-card-container {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .header-content {
      flex-direction: column;
      gap: 0.5rem;
    }
    
    .circle-decoration {
      width: 80px;
      height: 80px;
    }
  }

  /* Dark mode adjustments */
  :global(.dark) .case-studies-open-document-button {
    box-shadow: 0 4px 14px rgba(139, 92, 246, 0.3);
  }

  :global(.dark) .case-studies-open-document-button:hover {
    box-shadow: 0 8px 25px rgba(139, 92, 246, 0.4);
  }

  :global(.dark) .case-study-card:hover {
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }
</style>
